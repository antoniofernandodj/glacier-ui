// Componente reutilizável em KDL: recebe as props nome, cargo, inicial e cor.
// É puxado por `import` no painel_kdl.kdl — note que um .kdl pode importar
// outro .kdl (o motor escolhe o parser pela extensão de cada arquivo).
//
// Estiliza-se por atributos inline (auto-contido): a folha .gss escopada do
// painel não alcança aqui, pois um componente importado é avaliado no seu
// PRÓPRIO escopo, não no de quem o importa.
Container padding=15 width=320 background="#181825" border_radius=12 border_width=1 border_color="#313244" {
    Row spacing=15 align=Center {
        // Avatar circular com a inicial do nome (cor vem da prop).
        Container width=50 height=50 background="{cor}" border_radius=25 alignX=Center alignY=Center {
            Text "{inicial}" size=22 bold color="#11111B"
        }
        Column spacing=3 {
            Text "{nome}" size=18 bold color="#CDD6F4"
            Text "{cargo}" size=13 color="#A6ADC8"
        }
    }
}
