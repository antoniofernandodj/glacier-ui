/*
styles/painel_kdl.gss
Stylesheet COM ESCOPO do componente "painel_kdl", carregada pelo
`style "styles/painel_kdl.gss"` no template KDL.
Estas classes só valem dentro deste componente (no que ele renderiza
diretamente) e ficam EM CIMA das globais.
*/

.painel {
    padding: 30;
    width: fill;
    height: fill;
    background: #11111B;
    align-x: Center;
    align-y: Center;
}

.titulo {
    size: 28;
    bold: true;
    color: #F5E0DC;
}

.lista {
    spacing: 15;
}
