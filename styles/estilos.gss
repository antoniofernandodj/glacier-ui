/* 
styles/estilos.gss
Stylesheet COM ESCOPO do componente "estilos", carregada pelo
`<link rel="stylesheet" href="styles/estilos.gss" />` no template.
Estas classes só valem dentro deste componente e ficam EM CIMA das globais
(uma classe aqui com o mesmo nome de uma global venceria, localmente).
 */

.btn {
    padding: 10 20;
    color: #B4BEFE;
}

.btn-danger {
    color: #F38BA8;
}

.btn-success {
    color: #A6E3A1;
}
